# ai-code Environment Variables
# Copy this file to .env and fill in your values

# === LLM Configuration ===

# API key for your OpenAI-compatible provider (required)
AIC_API_KEY=sk-your-key-here

# Model name (default: gpt-4o)
# AIC_MODEL=gpt-4o

# OpenAI-compatible API base URL (default: https://api.openai.com/v1)
# AIC_API_BASE=https://api.openai.com/v1

# Temperature 0-2 (default: 0)
# AIC_TEMPERATURE=0

# === Alternative: use standard OpenAI env vars ===
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1

# === Logging ===

# Log level: silent | error | warn | info | debug (default: info)
# AIC_LOG_LEVEL=info

# === Display ===

# Terminal width override (default: auto-detect)
# AIC_WIDTH=80

# === Agent ===

# Enable verbose agent output (shows tool calls, intermediate steps)
# AIC_VERBOSE=false
