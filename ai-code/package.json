{
  "name": "ai-code",
  "version": "0.1.0",
  "description": "Terminal AI Coding Assistant - powered by LangChain",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aic": "dist/index.js"
  },
  "scripts": {
    "dev": "bun run --watch src/cli/index.ts",
    "start": "bun run src/cli/index.ts",
    "build": "bun run build:ts",
    "build:ts": "bunx tsc",
    "build:node": "bunx tsc --project tsconfig.node.json",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:node": "vitest run",
    "lint": "bunx eslint src/",
    "format": "bunx prettier --write src/"
  },
  "dependencies": {
    "@langchain/core": "^1.2.0",
    "@langchain/openai": "^1.5.0",
    "langchain": "^1.5.0",
    "zod": "^3.24.0",
    "commander": "^13.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "bun-types": "^1.2.0",
    "@types/node": "^22.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=22.0.0"
  },
  "keywords": [
    "ai",
    "coding",
    "assistant",
    "terminal",
    "langchain",
    "cli"
  ],
  "license": "MIT"
}
