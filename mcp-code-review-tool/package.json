{
  "name": "mcp-code-review-tool",
  "version": "0.1.0",
  "description": "MCP-based intelligent code review tool powered by LangChain",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-review": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:node": "node --watch --import tsx src/index.ts",
    "build": "bun run build:ts && bun run build:node-compat",
    "build:ts": "bunx tsc",
    "build:node-compat": "bunx tsc --project tsconfig.node.json && node -e \"require('fs').writeFileSync('dist/node/package.json', JSON.stringify({type:'commonjs'}))\"",
    "build:node-compat:node": "npx tsc --project tsconfig.node.json && node -e \"require('fs').writeFileSync('dist/node/package.json', JSON.stringify({type:'commonjs'}))\"",
    "start": "bun run dist/index.js",
    "start:node": "node --import tsx src/index.ts",
    "review": "bun run src/index.ts",
    "review:node": "node --import tsx src/index.ts --standalone",
    "build:binary": "node --import tsx scripts/build-binary.ts",
    "build:binary:bun": "bun run scripts/build-binary.ts --target bun",
    "build:binary:node": "node --import tsx scripts/build-binary.ts --target node",
    "build:binary:all": "node --import tsx scripts/build-binary.ts --target all",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:node": "vitest run",
    "lint": "bunx eslint src/",
    "format": "bunx prettier --write src/"
  },
  "dependencies": {
    "@langchain/core": "^1.2.0",
    "@langchain/anthropic": "^1.5.0",
    "@langchain/openai": "^1.5.0",
    "@langchain/community": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "langchain": "^1.5.0",
    "simple-git": "^3.36.0",
    "picocolors": "^1.1.0",
    "zod": "^3.24.0",
    "marked": "^18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "bun-types": "^1.2.0",
    "@types/node": "^22.0.0",
    "vitest": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "esbuild": "^0.25.0"
  },
  "optionalDependencies": {
    "pkg": "^5.8.0"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=22.0.0"
  },
  "keywords": [
    "mcp",
    "code-review",
    "langchain",
    "ai",
    "cli"
  ],
  "license": "MIT"
}
